# Supabase Configuration (NEW)
NEXT_PUBLIC_SUPABASE_URL=https://hirjgsyfolsvfqjayyfz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
DATABASE_SERVICE_ROLE_KEY=
# Server-only comma-separated super admin emails. Never prefix this with NEXT_PUBLIC_.
SUPER_ADMIN_EMAILS=elqallaf09@gmail.com
# Legacy server-only access code fallback for old debug endpoints. Prefer admin_roles permissions.
ADMIN_ACCESS_CODE=
CRON_SECRET=your_cron_secret_here
# Server-only salt used to hash visitor IPs for company analytics.
ANALYTICS_HASH_SALT=

# Stripe subscriptions (server only; use Price IDs that start with price_)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_YEARLY=
STRIPE_PRICE_COMPANY_YEARLY=
# Optional legacy premium price fallback. Prefer the explicit price IDs above.
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=

# OpenAI receipt scanning (server only)
OPENAI_API_KEY=
OPENAI_RECEIPT_MODEL=gpt-4.1-mini
OPENAI_NEWS_TRANSLATION_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_NEWS_TRANSLATION_MODEL=claude-3-5-haiku-latest
AI_GATEWAY_TOKEN=

# Daily per-account AI usage limits. Database rows in ai_usage_limits override these defaults.
AI_DAILY_LIMIT_DEFAULT=20
AI_RECEIPT_SCAN_DAILY_LIMIT=10
AI_MARKET_INSIGHT_DAILY_LIMIT=12
AI_MARKET_AGENT_DAILY_LIMIT=20
AI_PROJECT_ADVISOR_DAILY_LIMIT=12
AI_PROJECT_EXPENSE_DAILY_LIMIT=20
AI_PROJECT_PITCH_DECK_DAILY_LIMIT=8
AI_PROJECT_PITCH_DECK_EXPORT_DAILY_LIMIT=4
AI_PROJECTS_CHAT_DAILY_LIMIT=20
AI_DAILY_TIP_DAILY_LIMIT=3

# Metals prices (server only; never prefix these with NEXT_PUBLIC_)
METALS_API_URL=
METALS_API_KEY=
EXCHANGE_API_URL=
EXCHANGE_API_KEY=
USD_TO_KWD_RATE=

# Tech market news (server only; never prefix with NEXT_PUBLIC_)
FINNHUB_API_KEY=your_key_here

# Economic calendar (server only; priority: Finnhub, Trading Economics, FMP)
TRADING_ECONOMICS_API_KEY=
TRADING_ECONOMICS_BASE_URL=https://api.tradingeconomics.com
FMP_API_KEY=

# Economic-cycle macro indicators (server only; never prefix with NEXT_PUBLIC_)
# Trading Economics uses the shared TRADING_ECONOMICS_* variables above. FRED is a US-only fallback.
ECONOMIC_DATA_PROVIDER=tradingeconomics
FRED_API_KEY=
FRED_BASE_URL=https://api.stlouisfed.org/fred

# Market Analysis news and sentiment providers (server only; never prefix with NEXT_PUBLIC_)
# Central bank news defaults to NEWS_API_KEY and newsapi when provider vars are empty.
NEWS_PROVIDER=newsapi
NEWS_API_KEY=
CENTRAL_BANK_NEWS_PROVIDER=newsapi
CENTRAL_BANK_NEWS_API_KEY=
# Multi-source market-news ingestion. Custom feeds must be a server-side JSON
# array of reviewed HTTPS sources. Every custom hostname must also appear in
# the comma-separated allowlist; never expose either value through NEXT_PUBLIC_*.
FINANCIAL_NEWS_RSS_FEEDS_JSON=[]
FINANCIAL_NEWS_RSS_ALLOWED_HOSTS=
NEWS_FETCH_USER_AGENT=THE-SFM/1.0 (contact: ops@your-domain.example)
MARKET_NEWS_MAX_CONCURRENCY=4
MARKET_NEWS_PROVIDER_TIMEOUT_MS=8000

# Market sentiment defaults to Finnhub when FINNHUB_API_KEY exists, then Alpha Vantage when ALPHA_VANTAGE_API_KEY exists.
MARKET_SENTIMENT_PROVIDER=finnhub
MARKET_SENTIMENT_API_KEY=
ALPHA_VANTAGE_API_KEY=
# To use Myfxbook, set MARKET_SENTIMENT_PROVIDER=myfxbook and configure both credentials below.
# These are server-only values. Never prefix them with NEXT_PUBLIC_.
MYFXBOOK_EMAIL=
MYFXBOOK_PASSWORD=
# Optional. If omitted, the server defaults to https://www.myfxbook.com/api.
MYFXBOOK_API_BASE_URL=https://www.myfxbook.com/api
MARKET_PROVIDER_HEALTH_TOKEN=

# Private thesfm trader integration
# The protected page is /thesfm-trader-own and uses internal Next.js /api/trader/* routes.
# Do not configure localhost API destinations in Vercel Preview or Production.
THE_SFM_TRADER_REALTIME_WS_URL=
TRADER_DATA_PROVIDER=yahoo
TRADER_MACHINE_LEARNING_MODEL_URL=

# Professional trader data providers (server only)
POLYGON_API_KEY=
TWELVE_DATA_API_KEY=
EODHD_API_KEY=
MARKETSTACK_API_KEY=
REFINITIV_API_KEY=
BLOOMBERG_API_KEY=
OFFICIAL_EXCHANGE_API_URL=
OFFICIAL_EXCHANGE_API_KEY=

# Optional Shariah screening provider (server only; internal/manual screening works without these)
SHARIAH_SCREENING_PROVIDER=
SHARIAH_SCREENING_API_KEY=
SHARIAH_SCREENING_BASE_URL=

# Multi-source Shariah research (all optional; SEC, Nasdaq directories, Yahoo metadata, and public RSS work without keys)
# Identify this application in outbound public-source requests. Include a monitored contact URL or email in production.
SHARIA_RESEARCH_USER_AGENT=THE-SFM-ShariaResearch/1.0 (+https://www.the-sfm.com; public-source-research)
# Optional SearXNG-compatible/self-hosted discovery endpoint returning JSON { results: [{ title, url, content }] }.
SHARIA_RESEARCH_SEARCH_ENDPOINT=
SHARIA_RESEARCH_SEARCH_API_KEY=
# Disabled by default. Enables isolated, same-origin Playwright rendering only after normal HTTP extraction is insufficient.
SHARIA_RESEARCH_PLAYWRIGHT_FALLBACK=false

# Optional news translation (server only; never prefix with NEXT_PUBLIC_)
# If not configured, RSS/Finnhub headlines and excerpts remain in their original language.
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=
NEWS_ENABLE_PUBLIC_TRANSLATION_FALLBACK=false
MYMEMORY_EMAIL=

# Instagram automation (server only; never prefix with NEXT_PUBLIC_)
# Used by /sfm-admin-control/instagram-automation and /api/instagram-automation/*.
TELEGRAM_BOT_TOKEN=
INSTAGRAM_APPROVAL_TELEGRAM_CHAT_ID=
INSTAGRAM_GRAPH_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_GRAPH_API_VERSION=v21.0
APP_URL=

# Legacy (deprecated)
# NEXT_PUBLIC_DATABASE_URL=
# NEXT_PUBLIC_DATABASE_PUBLISHABLE_KEY=
