# Metals prices (server only; never prefix these with NEXT_PUBLIC_)
METALS_API_URL=
METALS_API_KEY=
EXCHANGE_API_URL=
EXCHANGE_API_KEY=
USD_TO_KWD_RATE=

# Tech market news (server only; never prefix with NEXT_PUBLIC_)
FINNHUB_API_KEY=your_key_here

# Economic calendar (server only; falls back to FINNHUB_API_KEY when API key is empty)
ECONOMIC_CALENDAR_PROVIDER=finnhub
ECONOMIC_CALENDAR_API_KEY=

# Market Analysis news and sentiment providers (server only; never prefix with NEXT_PUBLIC_)
# Central bank news defaults to NEWS_API_KEY and newsapi when provider vars are empty.
NEWS_PROVIDER=newsapi
NEWS_API_KEY=
CENTRAL_BANK_NEWS_PROVIDER=newsapi
CENTRAL_BANK_NEWS_API_KEY=

# Market sentiment defaults to Finnhub when FINNHUB_API_KEY exists, then Alpha Vantage when ALPHA_VANTAGE_API_KEY exists.
MARKET_SENTIMENT_PROVIDER=finnhub
MARKET_SENTIMENT_API_KEY=
ALPHA_VANTAGE_API_KEY=
# To use Myfxbook, set MARKET_SENTIMENT_PROVIDER=myfxbook and configure both credentials below.
# These are server-only values. Never prefix them with NEXT_PUBLIC_.
MYFXBOOK_EMAIL=
MYFXBOOK_PASSWORD=
# Optional. If omitted, the server defaults to https://www.myfxbook.com/api.
MYFXBOOK_API_BASE_URL=https://www.myfxbook.com/api
MARKET_PROVIDER_HEALTH_TOKEN=

# Private thesfm trader integration
# The protected page is /thesfm-trader-own and it proxies the trader API through /api/thesfm-trader/*.
THE_SFM_TRADER_API_BASE_URL=http://127.0.0.1:4173
THE_SFM_TRADER_REALTIME_WS_URL=
TRADER_DATA_PROVIDER=yahoo
TRADER_MACHINE_LEARNING_MODEL_URL=

# Professional trader data providers (server only)
POLYGON_API_KEY=
TWELVE_DATA_API_KEY=
REFINITIV_API_KEY=
BLOOMBERG_API_KEY=
OFFICIAL_EXCHANGE_API_URL=
OFFICIAL_EXCHANGE_API_KEY=

# Optional news translation (server only; never prefix with NEXT_PUBLIC_)
# If not configured, RSS/Finnhub headlines and excerpts remain in their original language.
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=

