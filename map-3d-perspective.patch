--- a/src/trader-app/public/cinema.css
+++ b/src/trader-app/public/cinema.css
@@ -5336,3 +5336,211 @@ a.badge:focus-visible,
 @media (prefers-reduced-motion: reduce) {
   .map-node.is-open i::after { display: none; animation: none; }
 }
+
+/* ═══════════════════════════════════════════════════════════════
+   MARKET MAP 3D — منظور بانورامي احترافي (يتغلّب على الكتل السابقة)
+   الطبقة تُمال للخلف بزاوية بسيطة لإحساس غرفة تحكم سينمائية،
+   والتسميات تُزاح باتجاهات مختلفة لفك تداخل مدن الخليج.
+   ═══════════════════════════════════════════════════════════════ */
+
+.world-map-3d {
+  position: relative;
+  min-height: 460px;
+  border: 1px solid var(--line);
+  border-radius: var(--radius-md);
+  background: radial-gradient(ellipse 80% 70% at 50% 30%, rgba(20, 46, 74, 0.5), rgba(2, 8, 15, 0.9) 75%);
+  overflow: hidden;
+  /* عمق المشهد: كل ما زاد، زاد الإحساس ثلاثي الأبعاد */
+  perspective: 1400px;
+  perspective-origin: 50% 32%;
+}
+
+/* المسرح يحمل المستوى المائل */
+.world-map-3d .map-stage {
+  position: absolute;
+  inset: 0;
+  transform-style: preserve-3d;
+}
+
+/* المستوى المائل للخلف — قلب التأثير ثلاثي الأبعاد */
+.world-map-3d .map-plane {
+  position: absolute;
+  inset: -6% -2% 2%;
+  transform-style: preserve-3d;
+  transform: rotateX(38deg) scale(1.04);
+  transform-origin: 50% 42%;
+  animation: map-breathe 22s ease-in-out infinite alternate;
+}
+
+@keyframes map-breathe {
+  from { transform: rotateX(38deg) scale(1.04); }
+  to { transform: rotateX(33deg) scale(1.06); }
+}
+
+/* صورة الخريطة على المستوى */
+.world-map-3d .world-map-img {
+  position: absolute;
+  inset: 0;
+  width: 100%;
+  height: 100%;
+  object-fit: cover;
+  opacity: 1;
+  filter: brightness(1.4) contrast(1.2) saturate(1.3) drop-shadow(0 0 22px rgba(34, 211, 238, 0.14));
+  pointer-events: none;
+  z-index: 1;
+}
+
+/* شبكة عمق تحت الخريطة تتلاشى نحو الأفق */
+.world-map-3d .map-grid-3d {
+  position: absolute;
+  inset: -20% -20% 0;
+  z-index: 0;
+  background-image:
+    repeating-linear-gradient(90deg, rgba(85, 215, 255, 0.06) 0 1px, transparent 1px 70px),
+    repeating-linear-gradient(0deg, rgba(85, 215, 255, 0.05) 0 1px, transparent 1px 60px);
+  mask-image: linear-gradient(180deg, transparent, black 30%, black 70%, transparent);
+  transform: translateZ(-40px);
+}
+
+/* الأقواس المتدفقة بين المدن */
+.world-map-3d .map-arcs {
+  position: absolute;
+  inset: 0;
+  width: 100%;
+  height: 100%;
+  z-index: 2;
+  transform: translateZ(10px);
+}
+
+.world-map-3d .map-arcs path {
+  fill: none;
+  stroke: rgba(85, 215, 255, 0.34);
+  stroke-width: 1.1;
+  stroke-dasharray: 3 8;
+  filter: drop-shadow(0 0 3px rgba(85, 215, 255, 0.4));
+  animation: mapdash 20s linear infinite;
+}
+
+/* العقدة: الدبوس يبقى على المدينة، والتسمية ترتفع فوق المستوى لتبقى مقروءة */
+.world-map-3d .map-node {
+  position: absolute;
+  z-index: 5;
+  transform-style: preserve-3d;
+}
+
+.world-map-3d .map-pin {
+  position: absolute;
+  top: 0;
+  left: 0;
+  width: 9px;
+  height: 9px;
+  border-radius: 50%;
+  transform: translate(-50%, -50%) translateZ(2px);
+}
+
+/* التسمية تُرفع عن المستوى (translateZ) فتبدو طافية بإحساس مجسّم */
+.world-map-3d .map-label {
+  position: absolute;
+  display: flex;
+  gap: 7px;
+  align-items: center;
+  padding: 4px 9px 4px 8px;
+  border: 0.5px solid rgba(143, 180, 205, 0.24);
+  border-radius: 999px;
+  background: rgba(3, 11, 19, 0.9);
+  box-shadow: 0 8px 20px rgba(0, 0, 0, 0.5);
+  white-space: nowrap;
+  /* إلغاء ميل المستوى عن النص ليبقى مواجهاً للقارئ + رفعه للأمام */
+  transform: rotateX(-38deg) translateZ(46px);
+  transform-origin: center;
+}
+
+.world-map-3d .map-label b {
+  color: #dbeafe;
+  font: 700 0.66rem var(--font-ar);
+  letter-spacing: 0.02em;
+}
+
+.world-map-3d .map-label small {
+  color: var(--muted-2);
+  font-size: 0.56rem;
+}
+
+/* اتجاهات إزاحة التسمية — تفصل مدن الخليج المتزاحمة */
+.world-map-3d .off-left .map-label { top: -8px; right: 16px; }
+.world-map-3d .off-right .map-label { top: -8px; left: 16px; }
+.world-map-3d .off-up .map-label { bottom: 16px; left: 50%; transform: rotateX(-38deg) translateZ(46px) translateX(-50%); }
+.world-map-3d .off-down .map-label { top: 18px; left: 50%; transform: rotateX(-38deg) translateZ(46px) translateX(-50%); }
+
+/* خط رفيع يربط التسمية المزاحة بدبوسها */
+.world-map-3d .map-node::after {
+  content: "";
+  position: absolute;
+  top: 0;
+  left: 0;
+  width: 14px;
+  height: 0.5px;
+  background: linear-gradient(90deg, rgba(143, 180, 205, 0.5), transparent);
+  transform-origin: left center;
+  opacity: 0.6;
+}
+
+.world-map-3d .off-up::after { transform: translate(-1px, -1px) rotate(-90deg); }
+.world-map-3d .off-down::after { transform: translate(-1px, 1px) rotate(90deg); }
+.world-map-3d .off-right::after { transform: scaleX(-1); }
+
+/* الجلسة المفتوحة: دبوس أخضر نابض بحلقة رادار */
+.world-map-3d .is-open .map-pin {
+  background: #45f0a2;
+  box-shadow: 0 0 12px rgba(69, 240, 162, 0.9);
+}
+
+.world-map-3d .is-open .map-pin::after {
+  content: "";
+  position: absolute;
+  inset: -4px;
+  border: 1px solid rgba(69, 240, 162, 0.7);
+  border-radius: 50%;
+  animation: node-ring 2.4s ease-out infinite;
+}
+
+.world-map-3d .is-open .map-label {
+  border-color: rgba(69, 240, 162, 0.35);
+}
+
+.world-map-3d .is-open .map-label b { color: #cdf7e3; }
+.world-map-3d .is-open .map-label small { color: rgba(69, 240, 162, 0.85); }
+
+/* الجلسة المغلقة: دبوس أحمر خافت */
+.world-map-3d .is-closed { opacity: 0.82; }
+.world-map-3d .is-closed .map-pin {
+  background: #ff6b74;
+  box-shadow: 0 0 7px rgba(255, 107, 116, 0.5);
+}
+.world-map-3d .is-closed .map-label b { color: var(--muted); }
+
+/* توهج عمق أسفل المشهد يعزز الإحساس ثلاثي الأبعاد */
+.world-map-3d .map-depth-glow {
+  position: absolute;
+  inset: auto 0 0;
+  height: 40%;
+  z-index: 3;
+  background: linear-gradient(0deg, rgba(2, 8, 15, 0.85), transparent);
+  pointer-events: none;
+}
+
+/* الجوال: تخفيف الميل حفاظاً على القراءة */
+@media (max-width: 720px) {
+  .world-map-3d { min-height: 300px; perspective: 900px; }
+  .world-map-3d .map-plane { transform: rotateX(30deg) scale(1.05); animation: none; }
+  .world-map-3d .map-label { transform: rotateX(-30deg) translateZ(30px); }
+  .world-map-3d .off-up .map-label,
+  .world-map-3d .off-down .map-label { transform: rotateX(-30deg) translateZ(30px) translateX(-50%); }
+  .world-map-3d .map-label small { display: none; }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .world-map-3d .map-plane { animation: none; }
+  .world-map-3d .map-arcs path { animation: none; }
+  .world-map-3d .is-open .map-pin::after { display: none; }
+}
