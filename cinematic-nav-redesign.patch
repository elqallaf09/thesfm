+/* ═══════════════════════════════════════════════════════════════
+   MARKET CINEMA — الخلفية السينمائية (شموع شبحية + خط سعر + جزيئات)
+   كلها transform/opacity فقط، طبقة fixed واحدة خلف المحتوى.
+   ═══════════════════════════════════════════════════════════════ */
+
+.market-cinema {
+  position: fixed;
+  inset: 0;
+  z-index: 0;
+  overflow: hidden;
+  pointer-events: none;
+}
+
+.terminal-app,
+.toast-root {
+  position: relative;
+  z-index: 1;
+}
+
+/* الشموع الشبحية: عنقود صاعد يسار وهابط يمين — إيحاء الصعود والنزول */
+.mc-candles {
+  position: absolute;
+  width: min(34vw, 480px);
+  height: min(52vh, 620px);
+  opacity: 0.055;
+}
+
+.mc-candles .mc-wick { stroke: #9fd8ef; stroke-width: 2; }
+.mc-candles .mc-body-up { fill: #10B981; }
+.mc-candles .mc-body-down { fill: #EF4444; }
+
+.mc-candles-bull {
+  bottom: -4vh;
+  left: 2vw;
+  animation: mc-drift-up 26s ease-in-out infinite alternate;
+}
+
+.mc-candles-bear {
+  top: -4vh;
+  right: 2vw;
+  animation: mc-drift-down 30s ease-in-out infinite alternate;
+}
+
+@keyframes mc-drift-up {
+  from { transform: translateY(14px) scale(1); }
+  to { transform: translateY(-18px) scale(1.03); }
+}
+
+@keyframes mc-drift-down {
+  from { transform: translateY(-14px) scale(1); }
+  to { transform: translateY(18px) scale(1.03); }
+}
+
+/* خط السعر المتوهج: يرسم نفسه ببطء ويتكرر — نبض السوق */
+.mc-priceline {
+  position: absolute;
+  inset: 0;
+  width: 100%;
+  height: 100%;
+  opacity: 0.5;
+}
+
+.mc-priceline .mc-line {
+  stroke-dasharray: 2400;
+  stroke-dashoffset: 2400;
+  filter: drop-shadow(0 0 6px rgba(34, 211, 238, 0.45));
+  animation: mc-draw 16s linear infinite;
+}
+
+.mc-priceline .mc-area {
+  opacity: 0;
+  animation: mc-area-fade 16s linear infinite;
+}
+
+.mc-priceline .mc-line-dot {
+  filter: drop-shadow(0 0 8px rgba(69, 240, 162, 0.9));
+  offset-path: path("M0 640 L120 600 L230 626 L340 540 L470 566 L600 470 L720 502 L840 420 L960 448 L1090 350 L1210 384 L1330 296 L1440 320");
+  animation: mc-dot-travel 16s linear infinite;
+}
+
+@keyframes mc-draw {
+  0% { stroke-dashoffset: 2400; opacity: 0; }
+  6% { opacity: 1; }
+  74% { stroke-dashoffset: 0; opacity: 1; }
+  92% { stroke-dashoffset: 0; opacity: 0.15; }
+  100% { stroke-dashoffset: 0; opacity: 0; }
+}
+
+@keyframes mc-area-fade {
+  0%, 8% { opacity: 0; }
+  60%, 78% { opacity: 1; }
+  95%, 100% { opacity: 0; }
+}
+
+@keyframes mc-dot-travel {
+  0% { offset-distance: 0%; opacity: 0; }
+  6% { opacity: 1; }
+  74% { offset-distance: 100%; opacity: 1; }
+  80%, 100% { offset-distance: 100%; opacity: 0; }
+}
+
+/* الجزيئات: خضراء تصعد وحمراء تهبط، كثافة قليلة جداً */
+.mc-p {
+  position: absolute;
+  width: 4px;
+  height: 4px;
+  border-radius: 50%;
+  opacity: 0;
+}
+
+.mc-p-up {
+  background: #10B981;
+  box-shadow: 0 0 8px rgba(16, 185, 129, 0.7);
+  animation: mc-float-up 18s linear infinite;
+}
+
+.mc-p-down {
+  background: #EF4444;
+  box-shadow: 0 0 8px rgba(239, 68, 68, 0.6);
+  animation: mc-float-down 20s linear infinite;
+}
+
+.mc-p-up:nth-of-type(1) { left: 12%; animation-delay: 0s; animation-duration: 17s; }
+.mc-p-up:nth-of-type(2) { left: 34%; animation-delay: 5s; animation-duration: 21s; }
+.mc-p-up:nth-of-type(3) { left: 58%; animation-delay: 10s; animation-duration: 19s; }
+.mc-p-up:nth-of-type(4) { left: 21%; animation-delay: 14s; animation-duration: 23s; }
+.mc-p-down:nth-of-type(5) { left: 72%; animation-delay: 3s; animation-duration: 22s; }
+.mc-p-down:nth-of-type(6) { left: 86%; animation-delay: 9s; animation-duration: 18s; }
+.mc-p-down:nth-of-type(7) { left: 64%; animation-delay: 15s; animation-duration: 24s; }
+
+@keyframes mc-float-up {
+  0% { bottom: -3%; opacity: 0; transform: translateX(0); }
+  12% { opacity: 0.55; }
+  88% { opacity: 0.4; }
+  100% { bottom: 104%; opacity: 0; transform: translateX(26px); }
+}
+
+@keyframes mc-float-down {
+  0% { top: -3%; opacity: 0; transform: translateX(0); }
+  12% { opacity: 0.5; }
+  88% { opacity: 0.35; }
+  100% { top: 104%; opacity: 0; transform: translateX(-26px); }
+}
+
+/* vignette: تركيز سينمائي على مركز الشاشة */
+.mc-vignette {
+  position: absolute;
+  inset: 0;
+  background: radial-gradient(ellipse 120% 90% at 50% 42%, transparent 52%, rgba(1, 4, 8, 0.55) 100%);
+}
+
+/* الجوال: طبقة أخف — شموع وجزيئات أقل حفاظاً على البطارية */
+@media (max-width: 720px) {
+  .mc-candles { width: 52vw; opacity: 0.04; }
+  .mc-p-up:nth-of-type(4), .mc-p-down:nth-of-type(7) { display: none; }
+  .mc-priceline { opacity: 0.35; }
+}
+
+/* احترام تفضيل تقليل الحركة */
+@media (prefers-reduced-motion: reduce) {
+  .mc-candles, .mc-p, .mc-priceline .mc-line, .mc-priceline .mc-area, .mc-priceline .mc-line-dot {
+    animation: none;
+  }
+  .mc-priceline .mc-line { stroke-dashoffset: 0; opacity: 0.6; }
+  .mc-priceline .mc-area { opacity: 0.7; }
+  .mc-priceline .mc-line-dot { display: none; }
+  .mc-p { display: none; }
+}
