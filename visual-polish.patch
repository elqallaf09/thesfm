+
+/* ═══════════════════════════════════════════════════════════════
+   VISUAL POLISH — تنظيف سطر التشخيص، حالات عدم التوفر، هياكل نابضة
+   ═══════════════════════════════════════════════════════════════ */
+
+/* صف تشخيص المزود: معلومة مطوّر — سطر mono واحد خافت،
+   نخفي الضجيج (fallback + أعلام المزودين + رمز المزود) ونبقي الاسم والوقت */
+.leadership-provider-row {
+  display: flex;
+  gap: 8px;
+  align-items: center;
+  justify-content: space-between;
+  margin-top: 8px;
+  padding-top: 8px;
+  border-top: 1px solid rgba(143, 167, 186, 0.1);
+  color: var(--muted-2);
+  font-family: var(--font-mono);
+  font-size: 0.58rem;
+  letter-spacing: 0.03em;
+  opacity: 0.75;
+}
+
+.leadership-provider-row > span {
+  display: none;
+}
+
+.leadership-provider-row b {
+  overflow: hidden;
+  font-weight: 600;
+  text-overflow: ellipsis;
+  white-space: nowrap;
+}
+
+.leadership-provider-row time {
+  flex-shrink: 0;
+}
+
+/* بطاقات القيادة غير المتاحة: باهتة ومنكمشة بصرياً بدل صناديق فارغة صارخة */
+.leadership-card:has(.signal-badge.unavailable) {
+  border-color: rgba(143, 167, 186, 0.1);
+  background: rgba(8, 20, 32, 0.4);
+  opacity: 0.55;
+  filter: saturate(0.5);
+  transition: opacity 180ms ease, filter 180ms ease;
+}
+
+.leadership-card:has(.signal-badge.unavailable):hover {
+  opacity: 0.85;
+  filter: saturate(0.85);
+}
+
+.leadership-card:has(.signal-badge.unavailable) .quality-badge {
+  opacity: 0.6;
+}
+
+/* خلايا الخريطة الحرارية غير المتاحة: هيكل نابض هادئ بدل نص مكرر صارخ */
+@keyframes mc-skeleton-pulse {
+  0%, 100% { background-color: rgba(8, 20, 32, 0.5); border-color: rgba(143, 167, 186, 0.1); }
+  50% { background-color: rgba(15, 34, 56, 0.55); border-color: rgba(143, 167, 186, 0.2); }
+}
+
+.opportunity-cell.unavailable,
+.heat-cell.unavailable {
+  animation: mc-skeleton-pulse 3.2s ease-in-out infinite;
+  opacity: 0.6;
+}
+
+.opportunity-cell.unavailable span,
+.opportunity-cell.unavailable em,
+.heat-cell.unavailable small,
+.heat-cell.unavailable em {
+  color: var(--muted-2);
+  opacity: 0.55;
+}
+
+.opportunity-cell.unavailable .asset-logo,
+.heat-cell.unavailable .asset-logo {
+  filter: grayscale(0.6);
+  opacity: 0.7;
+}
+
+.opportunity-cell.unavailable:hover,
+.heat-cell.unavailable:hover {
+  animation-play-state: paused;
+  opacity: 0.9;
+}
+
+/* تباعد أوسع بين مجموعات القائمة الجانبية */
+.nav-group-label {
+  margin-top: 18px;
+}
+
+.nav-group-label:first-child {
+  margin-top: 4px;
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .opportunity-cell.unavailable,
+  .heat-cell.unavailable {
+    animation: none;
+  }
+}
