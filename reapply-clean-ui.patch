index ebe071e..a953294 100644
--- a/src/trader-app/public/cinema.css
+++ b/src/trader-app/public/cinema.css
@@ -5190,3 +5190,133 @@ a.badge:focus-visible,
     max-width: 100%;
   }
 }
+
+/* ═══════════════════════════════════════════════════════════════
+   FINAL OVERRIDES — توافق نهائي (يكسب بالتتالي فوق كتل الثيمات)
+   الشعار المسطح + مساحة القائمة + شرائح مدن الخريطة وحالاتها
+   ═══════════════════════════════════════════════════════════════ */
+
+/* الشعار: صف نظيف نهائياً — يلغي أي صندوق/ظل من الثيمات السابقة */
+.brand-card,
+.terminal-sidebar .brand-card {
+  display: flex;
+  gap: 11px;
+  align-items: center;
+  min-height: 52px;
+  padding: 8px 6px;
+  border: none;
+  border-radius: 12px;
+  background: transparent;
+  box-shadow: none;
+}
+
+.brand-card:hover {
+  background: rgba(34, 211, 238, 0.05);
+}
+
+.brand-mark {
+  width: 36px;
+  height: 36px;
+  border-radius: 11px;
+  box-shadow: 0 0 14px rgba(69, 240, 162, 0.25);
+}
+
+.brand-card strong {
+  color: var(--text);
+  font-size: 0.98rem;
+  font-weight: 700;
+}
+
+/* القائمة تاخذ كامل الارتفاع بعد إزالة البطاقات السفلية */
+.sidebar-nav {
+  max-height: calc(100vh - 118px);
+}
+
+/* الخريطة: ارتفاع أكبر + وضوح صورة أعلى */
+.world-map {
+  min-height: 420px;
+}
+
+.world-map-img {
+  filter: brightness(1.35) contrast(1.18) saturate(1.25) drop-shadow(0 0 18px rgba(34, 211, 238, 0.12));
+  opacity: 1;
+}
+
+/* عقد المدن: شرائح مقروءة فوق الخريطة بدل نص عائم */
+.map-node {
+  z-index: 3;
+  display: flex;
+  gap: 7px;
+  align-items: center;
+  padding: 4px 9px 4px 7px;
+  border: 0.5px solid rgba(143, 180, 205, 0.22);
+  border-radius: 999px;
+  background: rgba(3, 11, 19, 0.82);
+  font: 600 0.64rem var(--font-ar);
+  white-space: nowrap;
+  transform: translate(-4px, -50%);
+}
+
+.map-node:hover {
+  border-color: rgba(85, 215, 255, 0.45);
+  background: rgba(5, 16, 27, 0.94);
+}
+
+.map-node b {
+  font-weight: 700;
+}
+
+.map-node small {
+  display: block;
+  color: var(--muted-2);
+  font-size: 0.58rem;
+  white-space: nowrap;
+}
+
+.map-node i {
+  position: relative;
+  flex-shrink: 0;
+  width: 8px;
+  height: 8px;
+  border-radius: 50%;
+  animation: none;
+}
+
+/* الجلسة المفتوحة: أخضر نابض بحلقة رادار */
+.map-node.is-open {
+  border-color: rgba(69, 240, 162, 0.3);
+}
+
+.map-node.is-open i {
+  background: #45f0a2;
+  box-shadow: 0 0 10px rgba(69, 240, 162, 0.85);
+}
+
+.map-node.is-open i::after {
+  position: absolute;
+  inset: -3px;
+  content: "";
+  border: 1px solid rgba(69, 240, 162, 0.7);
+  border-radius: 50%;
+  animation: node-ring 2.4s ease-out infinite;
+}
+
+.map-node.is-open b { color: #cdf7e3; }
+.map-node.is-open small { color: rgba(69, 240, 162, 0.8); }
+
+@keyframes node-ring {
+  0% { transform: scale(0.6); opacity: 1; }
+  100% { transform: scale(2.6); opacity: 0; }
+}
+
+/* الجلسة المغلقة: خافتة ساكنة */
+.map-node.is-closed { opacity: 0.72; }
+.map-node.is-closed i {
+  background: #ff6b74;
+  box-shadow: 0 0 6px rgba(255, 107, 116, 0.45);
+}
+.map-node.is-closed b { color: var(--muted); }
+
+@media (prefers-reduced-motion: reduce) {
+  .map-node.is-open i::after { display: none; animation: none; }
+}
